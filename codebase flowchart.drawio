        <mxCell id="CzHw7VR60xhRQRThsIUk-86" parent="CzHw7VR60xhRQRThsIUk-85" style="text;html=1;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;whiteSpace=wrap;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" value="This function computes the inverse mean free path, energy transfer ICDF and momentum transfer ICDFs for an arbitrary dielectric function. Also calculates the stopping power." vertex="1">
