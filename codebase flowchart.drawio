        </mxCell>
        <mxCell id="CzHw7VR60xhRQRThsIUk-87" parent="CzHw7VR60xhRQRThsIUk-85" style="text;html=1;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;whiteSpace=wrap;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" value="- First, the ELF Is pre-integrated by the functions q_part() and elf(). elf() makes a linear interpolation or extrapolation (i.e. given the by default 1200 points of omega the ELF is calculated for, interpolate or extrapolate if needed onto a new grid of points, e.g. 10000)" vertex="1">
          <mxGeometry height="70" width="470" y="80" as="geometry" />
